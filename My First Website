<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Random Facts for Filipinos</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
            padding: 40px;
            text-align: center;
        }

        h1 {
            color: #333;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .subtitle {
            color: #666;
            font-size: 1.1em;
            margin-bottom: 30px;
        }

        .fact-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 10px;
            margin-bottom: 30px;
            min-height: 300px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 1.2em;
            line-height: 1.6;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .fact-image {
            width: 100%;
            max-width: 200px;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 20px;
            animation: fadeIn 0.5s ease-in;
        }

        .fact-text {
            animation: fadeIn 0.5s ease-in;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        button {
            padding: 12px 30px;
            font-size: 1em;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .btn-next {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-next:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }

        .btn-next:active {
            transform: translateY(0);
        }

        .btn-reset {
            background: #f0f0f0;
            color: #333;
            border: 2px solid #667eea;
        }

        .btn-reset:hover {
            background: #667eea;
            color: white;
        }

        .counter {
            color: #999;
            font-size: 0.9em;
            margin-top: 20px;
        }

        .flag {
            font-size: 3em;
            margin-bottom: 15px;
        }

        @media (max-width: 600px) {
            .container {
                padding: 25px;
            }

            h1 {
                font-size: 2em;
            }

            .fact-box {
                min-height: 250px;
                font-size: 1em;
            }

            button {
                padding: 10px 20px;
                font-size: 0.9em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="flag">🇵🇭</div>
        <h1>Philippine Facts</h1>
        <p class="subtitle">Discover interesting facts about the Philippines</p>

        <div class="fact-box">
            <img id="factImage" class="fact-image" src="" alt="Fact illustration" style="display: none;">
            <div class="fact-text" id="factText">
                Click "Get New Fact" to learn something amazing!
            </div>
        </div>

        <div class="button-group">
            <button class="btn-next" onclick="getNewFact()">Get New Fact</button>
            <button class="btn-reset" onclick="resetFacts()">Reset</button>
        </div>

        <div class="counter">
            <span id="factCounter">Fact 0 of 20</span>
        </div>
    </div>

    <script>
        const facts = [
            {
                text: "The Philippines is the world's largest archipelago with 7,641 islands, though only about 2,000 are named.",
                image: "https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos are one of the few cultures in the world that celebrate their birthdays for a whole month, not just a single day.",
                image: "https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines is home to the world's smallest volcano, Taal Volcano, and the world's smallest active volcano complex.",
                image: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&h=300&fit=crop"
            },
            {
                text: "Jeepneys, iconic public transportation vehicles, are uniquely Filipino and are often called the 'King of the Road.'",
                image: "https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines has the world's longest Christmas season celebration, starting as early as September.",
                image: "https://images.unsplash.com/photo-1543589077-47d81606c1bf?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos have one of the most expressive and unique languages, with Tagalog being the official language and influenced by Spanish and English.",
                image: "https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=400&h=300&fit=crop"
            },
            {
                text: "Mano, the respectful gesture of taking the hand of an elder and pressing it to one's forehead, is a traditional Filipino sign of respect.",
                image: "https://images.unsplash.com/photo-1511632765486-a01980e01a18?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines is one of the world's top destinations for biodiversity, hosting thousands of endemic species found nowhere else.",
                image: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&h=300&fit=crop"
            },
            {
                text: "Bayanihan spirit, the Filipino tradition of helping one another voluntarily, reflects the strong sense of community among Filipinos.",
                image: "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines gave the world the gift of karaoke, which originated from Filipino music culture.",
                image: "https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos invented the yo-yo, which was originally a weapon used in hunting during ancient times.",
                image: "https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines has over 180 languages and dialects, making it one of the most linguistically diverse countries.",
                image: "https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=400&h=300&fit=crop"
            },
            {
                text: "Adobo, considered the national dish of the Philippines, is a culinary masterpiece with Spanish influence.",
                image: "https://images.unsplash.com/photo-1565299624946-b28f40a0ca4b?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos celebrate Sinulog Festival, one of Asia's largest festivals, featuring colorful parades and indigenous rituals.",
                image: "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines is known as the 'Pearl of the Orient Seas' due to its natural beauty and strategic location.",
                image: "https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=400&h=300&fit=crop"
            },
            {
                text: "Filipino martial arts, such as Eskrima, are among the world's oldest and most effective fighting systems.",
                image: "https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos have a strong sense of humor and are known for their ability to laugh even during difficult times.",
                image: "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippines has the world's oldest stone church still in use, built in 1587.",
                image: "https://images.unsplash.com/photo-1549144511-f099e773c147?w=400&h=300&fit=crop"
            },
            {
                text: "Filipinos are known for their strong family bonds and multigenerational households are common.",
                image: "https://images.unsplash.com/photo-1511632765486-a01980e01a18?w=400&h=300&fit=crop"
            },
            {
                text: "The Philippine peso is one of the most stable currencies in Southeast Asia, reflecting the country's economic resilience.",
                image: "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=400&h=300&fit=crop"
            }
        ];

        let currentFactIndex = -1;
        let usedIndices = [];

        function getNewFact() {
            // If all facts have been shown, reset the used indices
            if (usedIndices.length === facts.length) {
                usedIndices = [];
            }

            // Get a random index that hasn't been used yet
            let randomIndex;
            do {
                randomIndex = Math.floor(Math.random() * facts.length);
            } while (usedIndices.includes(randomIndex));

            usedIndices.push(randomIndex);
            currentFactIndex = randomIndex;

            // Display the fact with animation
            const factText = document.getElementById('factText');
            const factImage = document.getElementById('factImage');
            factText.style.animation = 'none';
            factImage.style.animation = 'none';
            setTimeout(() => {
                factText.textContent = facts[currentFactIndex].text;
                factImage.src = facts[currentFactIndex].image;
                factImage.style.display = 'block';
                factText.style.animation = 'fadeIn 0.5s ease-in';
                factImage.style.animation = 'fadeIn 0.5s ease-in';
            }, 10);

            updateCounter();
        }

        function resetFacts() {
            currentFactIndex = -1;
            usedIndices = [];
            document.getElementById('factText').textContent = 'Click "Get New Fact" to learn something amazing!';
            document.getElementById('factImage').style.display = 'none';
            updateCounter();
        }

        function updateCounter() {
            document.getElementById('factCounter').textContent = `Fact ${usedIndices.length} of ${facts.length}`;
        }

        // Load first fact automatically
        getNewFact();
    </script>
</body>
</html>
